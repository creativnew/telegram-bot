# ============================================================
# TELEGRAM BOT CONFIGURATION
# ============================================================
# Bot tokenini @BotFather dan oling
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Guruh egasining Telegram ID raqami
OWNER_ID=123456789

# Adminlar guruhining ID raqami (ixtiyoriy)
ADMIN_GROUP_ID=

# Asosiy guruh ID raqami (ixtiyoriy)
MAIN_GROUP_ID=

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DATABASE_PATH=data/bot_database.db

# ============================================================
# SECURITY SETTINGS
# ============================================================
# Webhook URL (production uchun)
WEBHOOK_URL=
RENDER_EXTERNAL_URL=

# Secret key for webhook validation
WEBHOOK_SECRET=your_random_secret_key_here

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_ENABLED=1
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=200

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_CHANNEL_ID=
